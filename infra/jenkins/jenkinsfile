pipeline {
    agent any

    environment {
        AWS_REGION = "me-central-1"
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages{
        stage("Checkout") {
            steps{
                checkout scm
            }
        }

        stage("Environment Variables") {
            steps{
                sh '''
                    echo "AWS Region: $AWS_REGION"
                    echo "Image Version: $IMAGE_TAG"
                '''
            }
        }

        stage("Terraform apply") {
            steps{
                dir(infra/terraform) {
                    sh '''
                        terraform init
                        ls
                    '''
                }
            }
        }

        stage("Build Image") {
            steps{
                sh '''
                    echo "Building image..."
                    pwd
                    tree -L 3
                '''
            }
        }

        stage("Push Image") {
            steps{
                sh '''
                    echo "Pushing image..."
                '''
            }
        }

        stage("Deploy Image") {
            steps{
                sh '''
                    echo "Deploying image..."
                '''
            }
        }

    }

    post {
        success {
            echo "Pipeline completed successfully"
        }

        failure {
            echo "Pipeline failed"
        }

        always {
            cleanWs()
        }
    }
}
