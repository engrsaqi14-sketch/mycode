pipeline {
    agent any

    environment {
        ENV = "dev"
    }

    stages{
        stage("Checkout") {
            steps{
                checkout scm
            }
        }

        stage("Environment Variables") {
            steps{
                sh '''
                    echo "Environment: $ENV"
                '''
            }
        }

        stage("Build Image") {
            steps{
                sh '''
                    echo "Building image..."
                '''
            }
        }

        stage("Push Image") {
            steps{
                sh '''
                    echo "Pushing image..."
                '''
            }
        }

        stage("Deploy Image") {
            steps{
                sh '''
                    echo "Deploying image..."
                '''
            }
        }

    }
    
    post {
        success {
            echo "Pipeline completed successfully"
        }

        failure {
            echo "Pipeline failed"
        }

        always {
            cleanWs()
        }
    }
}
